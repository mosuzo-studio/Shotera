---
import PageLayout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';

import { getHeaderData } from '~/navigation';
import { useTranslations, defaultLang, type Lang } from '~/i18n/utils';
import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const headerData = getHeaderData(lang);
---

<PageLayout metadata={metadata}>
  <Fragment slot="announcement">
    <slot name="announcement" />
  </Fragment>
  <Fragment slot="header">
    <slot name="header">
      <Header
        links={headerData?.links[2] ? [headerData.links[2]] : undefined}
        actions={[
          {
            text: t('action.download'),
            href: 'https://github.com/mosuzo-studio/Shotera',
          },
        ]}
        showToggleTheme
        position="right"
      />
    </slot>
  </Fragment>
  <slot />
</PageLayout>
