---
import Layout from '~/layouts/LandingLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '订阅落地页演示',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="订阅落地页演示"
    title="订阅落地页：把随手浏览的访客变成忠实订阅者！"
    subtitle="解锁订阅落地页的制胜公式，让你的受众一次次回访、欲罢不能。"
    actions={[
      { variant: 'primary', text: '立即行动', href: '#', icon: 'tabler:square-rounded-arrow-right' },
      { text: '了解更多', href: '#' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1593510987046-1f8fcfc512a0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: '与取消订阅相关的反讽图片。订阅落地页演示',
    }}
  />

  <CallToAction
    title="即将推出"
    subtitle="我们正在完善这些演示页面的内容，很快就能与你见面。敬请期待，敬请期待！"
    actions={[
      {
        variant: 'primary',
        text: '下载模板',
        href: 'https://github.com/mosuzo-studio/Shotera',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
