---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '产品详情落地页演示',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline="产品详情演示"
    title="产品落地页：以精准与热情尽情展示！"
    subtitle="循序渐进的指南，帮你设计一个全方位呈现产品或服务每一处细节的落地页。"
    actions={[
      { variant: 'primary', text: '立即行动', href: '#', icon: 'tabler:square-rounded-arrow-right' },
      { text: '了解更多', href: '#' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1473188588951-666fce8e7c68?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2174&q=80',
      alt: '聚光灯下的产品。产品详情落地页演示',
    }}
  />

  <CallToAction
    title="即将推出"
    subtitle="我们正在完善这些演示页面的内容，很快就能与你见面。敬请期待，敬请期待！"
    actions={[
      {
        variant: 'primary',
        text: '下载模板',
        href: 'https://github.com/mosuzo-studio/Shotera',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
